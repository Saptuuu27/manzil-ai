# ============================================
# Manzil AI — Environment Variables
# ============================================
# Copy this file to .env and fill in your API keys
# Set USE_REAL_APIS=true to activate all real APIs

PORT=5000

# ─── Google Gemini AI (Required for AI alerts) ─────────────────
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Google Maps Platform (Required for real routes) ───────────
# Enable: Directions API + Places API (Nearby Search)
# Get key: https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── Twilio SMS (Required for real SMS alerts) ─────────────────
# Get credentials: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── OpenWeatherMap (Required for real weather) ────────────────
# Get key: https://openweathermap.org/api (free tier available)
OPENWEATHER_API_KEY=your_openweather_api_key

# ─── Mode ──────────────────────────────────────────────────────
# Set to "true" to use real APIs, "false" for demo/mock mode
USE_REAL_APIS=false

# ─── CORS (Production frontend URL) ───────────────────────────
# Add your Firebase Hosting URL here
ALLOWED_ORIGINS=http://localhost:5173,https://manzil-ai.web.app,https://manzil-ai.firebaseapp.com
